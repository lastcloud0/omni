# Copy this file to .env.local and fill in your keys.
# Without keys, OMNI still runs using the browser's built-in speech APIs.

# ── AI 두뇌(어댑터) ───────────────────────────────────────────
# 껍데기(UI)는 lib/aiClient.ts 의 askAI() 만 호출합니다.
# 기존에 쓰던 AI 소스가 있으면 그 주소만 여기에 넣으세요. UI 코드 수정 불필요.
# 비워두면 내장 /api/chat (OpenAI) 라우트를 사용합니다.
NEXT_PUBLIC_AI_ENDPOINT=

# Google Gemini (무료) — 내장 /api/chat 라우트의 두뇌.
# https://aistudio.google.com → "Get API key" 에서 카드 없이 발급.
GEMINI_API_KEY=

# ElevenLabs — used by /api/tts for movie-grade voice. Falls back to
# browser SpeechSynthesis when empty.
ELEVENLABS_API_KEY=
# Default voice id (Rachel). Replace with any voice id from your account.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
